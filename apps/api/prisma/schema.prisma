// ===========================================================================
// Lumio Booking - Multi-tenant SaaS database schema (PostgreSQL)
// ---------------------------------------------------------------------------
// Design rules (enforced by code review + tests):
//   * `Tenant` is the root entity. One Tenant == one nail salon.
//   * Every tenant-scoped table carries `tenantId` and is indexed on it.
//   * Platform-level tables (Plan, and SUPER_ADMIN rows in User) are NOT
//     tenant-scoped on purpose.
//   * All cross-tenant access is forbidden; queries are scoped by the
//     authenticated tenantId in the service/repository layer.
// ===========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// ENUMS
// ===========================================================================

/// Sub-role for a STAFF user inside one salon, driving feature permissions.
/// (The salon owner is a SALON_ADMIN user; SUPER_ADMIN is the platform team.)
enum StaffRole {
  MANAGER // Almost full access (no billing/integrations/settings)
  RECEPTIONIST // Front desk + POS (cashier)
  TECHNICIAN // Own schedule/work only (staff portal)
}

enum UserRole {
  SUPER_ADMIN // Lumio platform team (no tenantId)
  SALON_ADMIN // Salon owner/manager (scoped to one tenant)
  STAFF // Technician (scoped to one tenant)
}

enum TenantStatus {
  PENDING // Signed up, awaiting first payment/activation
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum AppointmentStatus {
  PENDING // Created, not yet assigned to a staff member
  ASSIGNED // Assigned to a staff member, awaiting their response
  ACCEPTED // Staff accepted the assignment
  REJECTED // Staff rejected; needs re-assignment
  CONFIRMED // Confirmed (e.g. after payment / admin confirm)
  ARRIVED // Customer has checked in / is in the salon
  CANCELLED // Cancelled by customer or salon
  COMPLETED // Service delivered
  NO_SHOW // Customer did not show up
}

enum RejectionType {
  REJECTED // Staff explicitly rejected
  NO_RESPONSE // Staff did not respond before the deadline
}

enum AssignmentRuleType {
  REJECTION_THRESHOLD // Too many rejections in a window
  NO_RESPONSE_THRESHOLD // Too many no-responses in a window
  REJECTION_RATE // Rejection rate above a % with min assignments
  PERFORMANCE_SCORE // Weight by performance score
  PREFERRED_STAFF // Honor customer's preferred staff
  FAIR_DISTRIBUTION // Spread bookings evenly
}

enum PaymentType {
  PAY_ONLINE
  PAY_LATER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// ===========================================================================
// PLATFORM-LEVEL TABLES (NOT tenant-scoped)
// ===========================================================================

/// Subscription plans offered by Lumio (Basic, Pro, ...). Feature limits live
/// here; a Tenant points to one Plan via its Subscription.
model Plan {
  id              String          @id @default(uuid())
  name            String
  description     String?
  priceCents      Int             @default(0)
  currency        String          @default("USD")
  billingInterval BillingInterval @default(MONTHLY)

  // Self-serve pricing (cents). Yearly is usually ~10 months for a discount.
  priceMonthlyCents Int @default(0)
  priceYearlyCents  Int @default(0)
  trialDays         Int @default(14)

  // Marketing (public landing page).
  tagline       String?
  featuresJson  Json    @default("[]") // string[] of selling points
  publicVisible Boolean @default(false)
  highlighted   Boolean @default(false) // "Most popular" badge
  sortOrder     Int     @default(0)

  // External billing references (created in the Stripe/PayPal dashboards).
  stripePriceMonthlyId String?
  stripePriceYearlyId  String?
  paypalPlanMonthlyId  String?
  paypalPlanYearlyId   String?

  // Feature limits (business model). Null = unlimited.
  maxStaff             Int?
  maxBookingsPerMonth  Int?
  maxSmsPerMonth       Int?
  posEnabled           Boolean @default(false) // unlocks POS / Products / Orders / Sales report
  onlinePaymentEnabled Boolean @default(false)
  multiLocationEnabled Boolean @default(false)
  whiteLabelEnabled    Boolean @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("plans")
}

// ===========================================================================
// TENANT ROOT
// ===========================================================================

/// The root entity. One row per nail salon (tenant).
model Tenant {
  id       String       @id @default(uuid())
  name     String
  slug     String       @unique // URL-safe identifier, also used for routing
  status   TenantStatus @default(ACTIVE)
  timezone String       @default("UTC")

  contactEmail String?
  contactPhone String?

  // Branding settings for future white-label (logo URL, colors, etc.)
  branding Json @default("{}")

  // Per-feature access policy set by Super Admin: { [featureKey]: 'salon' | 'platform' }.
  // 'platform' = hidden from the salon UI AND write-blocked at the API (protects
  // Lumio's internal process). Missing key = feature's built-in default (usually salon).
  featurePolicy Json @default("{}")

  // Current plan (denormalized convenience pointer); source of truth for
  // billing periods is the Subscription rows.
  planId             String?
  plan               Plan?              @relation(fields: [planId], references: [id])
  subscriptionStatus SubscriptionStatus @default(TRIALING)

  // Multi-branch: when set, this tenant is one branch within a chain/owner group.
  // Each branch is still a fully isolated tenant; the group only lets an owner
  // login switch between, and report across, its branches.
  accountGroupId String?
  accountGroup   AccountGroup? @relation(fields: [accountGroupId], references: [id], onDelete: SetNull)

  // Super-admin access overrides (independent of billing):
  //  - billingExempt: free salon, always open, never needs payment.
  //  - accessUntil: hard expiry; past this the salon is locked until extended.
  billingExempt Boolean   @default(false)
  accessUntil   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relations (all tenant-scoped children)
  users             User[]
  subscriptions     Subscription[]
  apiKeys           ApiKey[]
  wordpressSites    WordpressSite[]
  services          Service[]
  serviceAddons     ServiceAddon[]
  staffMembers      StaffMember[]
  workingHours      StaffWorkingHour[]
  staffServices     StaffService[]
  customers         Customer[]
  appointments      Appointment[]
  payments          Payment[]
  notifications     Notification[]
  bookingRejections BookingRejection[]
  assignmentRules   AssignmentRule[]
  settings          Setting[]
  auditLogs         AuditLog[]
  serviceCategories ServiceCategory[]
  feedbacks         Feedback[]
  staffRewardTransactions StaffRewardTransaction[]
  reviewClicks      ReviewClick[]
  googleReviews     GoogleReview[]
  messengerConnection MessengerConnection?
  messengerThreads  MessengerThread[]
  waitlistEntries   WaitlistEntry[]
  walkIns           WalkIn[]
  supplyItems       SupplyItem[]
  supplyMovements   SupplyMovement[]
  products          Product[]
  displaySession    DisplaySession?
  orders            Order[]
  orderItems        OrderItem[]
  orderPayments     OrderPayment[]
  loyaltyTransactions LoyaltyTransaction[]
  branchMemberships BranchMembership[]
  printJobs         PrintJob[]
  giftCards            GiftCard[]
  giftCardTransactions GiftCardTransaction[]
  tipLogs              TipLog[]
  voiceLine            VoiceLine?
  voiceCalls           VoiceCall[]
  invoices             Invoice[]

  @@index([status])
  @@index([accountGroupId])
  @@map("tenants")
}

/// Billing subscription history for a tenant.
model Subscription {
  id       String             @id @default(uuid())
  tenantId String
  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId   String
  plan     Plan               @relation(fields: [planId], references: [id])
  status   SubscriptionStatus @default(TRIALING)

  interval BillingInterval @default(MONTHLY)
  provider String? // 'stripe' | 'paypal'

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?

  // External billing references. externalReference = provider subscription id
  // (used as the webhook lookup key); externalCustomerId = Stripe customer id.
  externalReference  String? @unique
  externalCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("subscriptions")
}

// ===========================================================================
// USERS & AUTH (backend's own user system - NOT WordPress users)
// ===========================================================================

/// Backend user accounts. SUPER_ADMIN has tenantId = null; SALON_ADMIN and
/// STAFF always belong to exactly one tenant. Email is globally unique to keep
/// login simple.
model User {
  id           String   @id @default(uuid())
  tenantId     String? // null only for SUPER_ADMIN
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Multi-branch: chain-level users (owner/manager) belong to an AccountGroup and
  // can switch between its branches. Null = single-salon user (current behavior).
  accountGroupId String?
  accountGroup   AccountGroup? @relation(fields: [accountGroupId], references: [id], onDelete: SetNull)
  role         UserRole
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?

  // If this user is a technician, this links to their StaffMember profile.
  staffMember StaffMember?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]
  branchMemberships BranchMembership[]

  @@index([tenantId])
  @@index([role])
  @@index([accountGroupId])
  @@map("users")
}

// A chain / owner group: links multiple Tenant "branches" under one owner account.
// Each branch remains a fully isolated tenant — this layer only lets an owner (and
// granted managers) switch between branches and view consolidated reporting.
model AccountGroup {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenants Tenant[]
  users   User[]

  @@map("account_groups")
}

// Grants a (manager) user access to an additional branch beyond their home tenant.
// Owners get all branches in their group implicitly; managers are explicit here.
model BranchMembership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@map("branch_memberships")
}

// ===========================================================================
// WORDPRESS PLUGIN CONNECTION
// ===========================================================================

/// A WordPress site connected to a tenant. One site links to exactly one
/// tenant (unless explicitly configured otherwise in the future).
model WordpressSite {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String?
  siteUrl  String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys ApiKey[]

  @@unique([tenantId, siteUrl])
  @@index([tenantId])
  @@map("wordpress_sites")
}

/// API / license keys used by the WordPress plugin to authenticate to the
/// backend. Only a HASH of the key is stored (never the plaintext). Keys are
/// revocable. The plugin stores the plaintext on the WordPress side, not here.
model ApiKey {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  wordpressSiteId String?
  wordpressSite   WordpressSite? @relation(fields: [wordpressSiteId], references: [id], onDelete: SetNull)

  name      String? // Human label, e.g. "Main website"
  keyHash   String       @unique // Hash of the full key (e.g. bcrypt/sha256)
  keyPrefix String // First few public chars for identification in UI
  lastFour  String // Last 4 chars for display, e.g. "...a1b2"
  status    ApiKeyStatus @default(ACTIVE)

  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("api_keys")
}

// ===========================================================================
// SERVICES
// ===========================================================================

model Service {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  durationMinutes Int
  priceCents      Int     @default(0)
  discountPercent Int     @default(0) // 0–90: optional promo discount shown to customers
  currency        String  @default("USD")
  isActive        Boolean @default(true)

  // Menu organisation for long catalogs.
  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sortOrder  Int              @default(0)
  isFeatured Boolean          @default(false) // "Popular" highlight
  priceFrom  Boolean          @default(false) // show "from $X" (price varies)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staffServices StaffService[]
  appointments  Appointment[]
  addons        ServiceAddon[]
  waitlistEntries WaitlistEntry[]
  walkIns         WalkIn[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, categoryId])
  @@map("services")
}

/// Platform-level key/value config (e.g. the Lumio Stripe/PayPal API keys set
/// by the Super Admin). NOT tenant-scoped. Values may be secrets.
model PlatformConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_config")
}

/// Menu groups (e.g. "Hand & Feet Care", "Artificial Nails"). Tenant-scoped.
model ServiceCategory {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  icon      String? // optional emoji/icon name
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services Service[]

  @@index([tenantId])
  @@map("service_categories")
}

/// Optional extras a customer can add to a service at booking time
/// (e.g. "Nail art", "French tips"). Each adds price and time.
model ServiceAddon {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  name            String
  durationMinutes Int     @default(0)
  priceCents      Int     @default(0)
  currency        String  @default("USD")
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([serviceId])
  @@map("service_addons")
}

// ===========================================================================
// STAFF / TECHNICIANS
// ===========================================================================

model StaffMember {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Optional login account (a staff member may or may not log in).
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  firstName String
  lastName  String?
  email     String?
  phone     String?
  avatarUrl String? // public image URL shown on the booking page
  isActive  Boolean @default(true)

  // Used by the assignment rule engine. Higher = preferred.
  performanceScore Int @default(100)

  // POS service commission rate (percent of service revenue this tech earns).
  commissionPercent Int @default(0)

  // Optional fixed base pay per pay period (cents). Added on top of commission +
  // tips when running payroll. 0 = commission-only (the default).
  baseCents Int @default(0)

  // Feature-permission role for this staff member's login (if they have one).
  staffRole StaffRole @default(TECHNICIAN)

  // Whether this person is a bookable technician: shows in the booking page,
  // calendar, walk-in assignment and the auto-assign engine. Receptionists and
  // managers default to false (front-desk/management only), but an owner who
  // also does nails can be flipped back on. Decoupled from staffRole on purpose.
  takesAppointments Boolean @default(true)

  // Review-reward program: lifetime points balance.
  rewardPoints Int @default(0)

  // Booking-list ordering: admin priority (0 = auto/fair; higher = pinned first).
  bookingPriority Int @default(0)

  // Direct tipping: the tech's own payment QR (uploaded image) + an optional
  // handle/link (Venmo / Zelle / Cash App / PayPal) shown to customers. Tips paid
  // this way go straight to the tech — the salon only logs them, never holds the money.
  tipQrUrl  String?
  tipHandle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workingHours       StaffWorkingHour[]
  staffServices      StaffService[]
  assignedBookings   Appointment[]      @relation("AssignedStaff")
  preferredBookings  Appointment[]      @relation("PreferredStaff")
  bookingRejections  BookingRejection[]
  feedbacks          Feedback[]
  rewardTransactions StaffRewardTransaction[]
  reviewClicks       ReviewClick[]
  walkIns            WalkIn[]               @relation("WalkInStaff")
  tipLogs            TipLog[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("staff_members")
}

/// A customer's post-service rating (your own feedback form). Drives staff
/// reward points and the salon's CSAT; the Google review is invited separately.
model Feedback {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  staffId    String?
  staff      StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)
  customerId String?
  customer   Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  rating          Int // 1–5
  comment         String?
  invitedToGoogle Boolean @default(false) // did we show them the Google button

  // Anti-abuse: rewardable feedback must be anchored to a real visit.
  appointmentId String? // the matched appointment (one reward per visit)
  verified      Boolean @default(false) // passed real-visit + limit checks → points awarded

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, staffId])
  @@index([tenantId, appointmentId])
  @@map("feedbacks")
}

/// Ledger of staff reward-point changes (earn from feedback, redeem by admin).
model StaffRewardTransaction {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  staffId String
  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  points       Int
  balanceAfter Int
  reason       String
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, staffId])
  @@map("staff_reward_transactions")
}

/// A logged "send to Google" tap from the direct-review landing. Drives staff
/// stats (how many customers each tech sent to Google) and gates reward points
/// (deduped per device + daily cap). NOTE: Google gives no callback, so this
/// counts sends/intent — NOT confirmed posted reviews.
model ReviewClick {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  staffId String?
  staff   StaffMember? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  deviceId String? // anonymous per-device id (localStorage) used for dedupe
  ipHash   String? // hashed IP — coarse dedupe / abuse signal
  counted  Boolean @default(false) // passed all fraud checks → earned reward points
  reason   String? // why it was / wasn't counted: ok | dedup | cap | over-visits | off-hours | disabled

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, staffId])
  @@index([tenantId, staffId, createdAt])
  @@map("review_clicks")
}

enum WaitlistStatus {
  WAITING // still hoping for a slot
  NOTIFIED // salon told them a slot opened
  CONVERTED // turned into a booking
  CANCELLED // no longer interested / removed
}

/// A customer waiting for a slot. When a booking is cancelled the salon can
/// notify matching entries to fill the gap (and win back demand).
model WaitlistEntry {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  customerName  String
  phone         String?
  email         String?
  preferredDate String? // 'YYYY-MM-DD' the customer would like (optional)
  note          String?
  status        WaitlistStatus @default(WAITING)

  createdAt  DateTime  @default(now())
  notifiedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("waitlist_entries")
}

/// Walk-in queue + fair turn rotation (nail-salon "lượt"). Each walk-in client
/// is added to the queue and assigned to a technician; turns are counted per
/// tech per day so the front desk can hand the next client to whoever is "up".
enum WalkInStatus {
  WAITING // in the queue, not yet handed to a tech
  SERVING // assigned to a tech, in progress
  DONE // finished (counts as a completed turn)
  CANCELLED // left / removed
}

model WalkIn {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  assignedStaffId String?
  assignedStaff   StaffMember? @relation("WalkInStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  // Linked CRM customer (found/created by phone) so a walk-in earns loyalty and
  // becomes remarketable. Optional: a walk-in with no phone has no linked record.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  customerName String?
  phone        String?
  note         String?
  partySize    Int     @default(1)

  status WalkInStatus @default(WAITING)

  createdAt  DateTime  @default(now())
  assignedAt DateTime?
  doneAt     DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedStaffId])
  @@index([tenantId, customerId])
  @@map("walk_ins")
}

// Back-of-house supplies/consumables a salon stocks (nail polish, tips, powder,
// acetone…). Distinct from `Product` (retail items sold to customers). Tracks the
// current quantity and a low-stock threshold for reorder alerts.
model SupplyItem {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name              String
  unit              String  @default("unit") // bottle, box, pack…
  stockQty          Int     @default(0)
  lowStockThreshold Int     @default(0) // stockQty <= this → low-stock alert
  costCents         Int? // optional unit cost (for inventory value)
  supplier          String?
  isActive          Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements SupplyMovement[]

  @@index([tenantId])
  @@map("supply_items")
}

/// Why stock moved in/out — drives the inventory in/out log ("sổ nhập/xuất kho").
enum StockMoveReason {
  PURCHASE // received / bought in (IN)
  USE // consumed for services (OUT)
  DAMAGE // damaged / wasted / lost (OUT)
  RETURN // returned to supplier (OUT)
  ADJUST // stock-count correction (IN or OUT)
}

/// One stock movement for a supply item. `delta` is signed (+in / -out). The
/// running stockQty on SupplyItem is derived by applying these.
model SupplyMovement {
  id           String @id @default(uuid())
  tenantId     String
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplyItemId String
  supplyItem   SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)

  delta         Int // signed quantity: positive = stock in, negative = stock out
  reason        StockMoveReason
  note          String?
  unitCostCents Int? // optional, for PURCHASE (cost per unit)
  createdById   String? // the staff/admin who recorded it

  createdAt DateTime @default(now())

  @@index([tenantId, supplyItemId])
  @@map("supply_movements")
}

/// Weekly recurring working hours for a staff member.
model StaffWorkingHour {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0 = Sunday ... 6 = Saturday
  startTime String // "09:00" (salon local time)
  endTime   String // "17:30"
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([staffMemberId])
  @@map("staff_working_hours")
}

/// Join table: which services a staff member can perform (skills).
model StaffService {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([staffMemberId, serviceId])
  @@index([tenantId])
  @@map("staff_services")
}

// ===========================================================================
// CUSTOMERS (END CUSTOMERS / CLIENTS)
// ===========================================================================

model Customer {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String?
  email     String?
  phone     String?
  notes     String?

  // Date of birth (optional) — drives the automated birthday campaign. Only the
  // month/day are used for matching; the year is informational.
  birthDate DateTime?

  // Loyalty points balance (earned on paid visits, spent on rewards).
  loyaltyPoints Int @default(0)

  // Explicit opt-in for promotional SMS (A2P 10DLC). Transactional reminders do
  // not depend on this; marketing messages must respect it. smsConsentAt records
  // when consent was captured, as proof.
  smsConsent   Boolean   @default(false)
  smsConsentAt DateTime?

  // Referral program. referralCode is this customer's personal share code;
  // referredById links a NEW customer to whoever referred them; referralRewardedAt
  // marks that the referrer reward has been granted (so it happens once).
  referralCode       String?
  referredById       String?
  referredBy         Customer?  @relation("CustomerReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals          Customer[] @relation("CustomerReferrals")
  referralRewardedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments        Appointment[]
  loyaltyTransactions LoyaltyTransaction[]
  feedbacks           Feedback[]
  walkIns             WalkIn[]

  // A customer email is unique within a tenant (not across the platform).
  @@unique([tenantId, email])
  // A referral code is unique within a tenant.
  @@unique([tenantId, referralCode])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([tenantId, referredById])
  @@map("customers")
}

// ===========================================================================
// APPOINTMENTS / BOOKINGS
// ===========================================================================

model Appointment {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  // Staff actually assigned to perform the service.
  assignedStaffId String?
  assignedStaff   StaffMember? @relation("AssignedStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)

  // Staff the customer requested (optional preference).
  preferredStaffId String?
  preferredStaff   StaffMember? @relation("PreferredStaff", fields: [preferredStaffId], references: [id], onDelete: SetNull)

  status AppointmentStatus @default(PENDING)

  startTime DateTime
  endTime   DateTime

  priceCents Int    @default(0)
  currency   String @default("USD")
  notes      String?

  // Snapshot of the add-ons the customer selected, e.g.
  // [{ "id": "...", "name": "Nail art", "priceCents": 1500, "durationMinutes": 15 }]
  addons Json @default("[]")

  // Deadline for the assigned staff to accept/reject before reassignment.
  responseDeadline DateTime?

  // Lifecycle timestamps
  assignedAt  DateTime?
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  confirmedAt DateTime?
  arrivedAt   DateTime? // customer checked in at the salon
  cancelledAt DateTime?
  completedAt DateTime?

  // No-show reduction: timestamps so each automated reminder fires at most once.
  remind1SentAt DateTime? // earlier reminder (e.g. 24h before) sent
  remind2SentAt DateTime? // later reminder (e.g. ~2-3h before) sent
  customerConfirmedAt DateTime? // customer tapped "Confirm" in a reminder

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments          Payment[]
  bookingRejections BookingRejection[]

  // NOTE on double-booking: a hard guarantee that one staff member is not
  // double-booked for an overlapping time range cannot be expressed as a plain
  // Prisma unique constraint (it needs a range/exclusion constraint). This is
  // enforced in the booking service via a transaction + row lock, plus a
  // PostgreSQL EXCLUDE constraint added in a later migration. These indexes
  // support the overlap lookup efficiently.
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedStaffId, startTime])
  @@index([tenantId, startTime])
  @@map("appointments")
}

/// History of staff rejections and no-responses (feeds the rule engine).
model BookingRejection {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  type   RejectionType
  reason String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, staffMemberId, createdAt])
  @@map("booking_rejections")
}

/// Configurable rules for the assignment engine. `config` holds rule-specific
/// thresholds/windows as JSON so new rules don't require schema changes.
model AssignmentRule {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String
  type     AssignmentRuleType
  // e.g. { "maxRejections": 3, "windowDays": 7, "priorityPenalty": 50 }
  config   Json               @default("{}")
  priority Int                @default(0) // Higher runs first
  isActive Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("assignment_rules")
}

// ===========================================================================
// PAYMENTS
// ===========================================================================

model Payment {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  amountCents Int
  currency    String        @default("USD")
  type        PaymentType   @default(PAY_LATER)
  status      PaymentStatus @default(PENDING)

  // Provider abstraction: "mock" now, "stripe" later. No secret keys stored.
  provider          String  @default("mock")
  providerReference String?

  paidAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("payments")
}

// ===========================================================================
// NOTIFICATIONS
// ===========================================================================

model Notification {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  channel   NotificationChannel
  recipient String // email address or phone number
  subject   String?
  body      String

  status   NotificationStatus @default(PENDING)
  provider String             @default("mock") // mock | sendgrid | twilio | ...
  error    String?

  // Loose link to the resource that triggered this notification.
  relatedType String? // e.g. "appointment"
  relatedId   String?

  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("notifications")
}

// ===========================================================================
// SETTINGS (per-tenant key/value, e.g. SMS/email config, booking rules)
// ===========================================================================

model Setting {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key   String
  value Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("settings")
}

// ===========================================================================
// AUDIT LOGS
// ===========================================================================

/// Important actions. tenantId/userId are nullable so platform-level
/// SUPER_ADMIN actions can also be logged.
model AuditLog {
  id       String  @id @default(uuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action       String // e.g. "tenant.suspended", "service.created"
  resourceType String? // e.g. "tenant", "service"
  resourceId   String?
  metadata     Json    @default("{}")
  ipAddress    String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ===========================================================================
// GOOGLE REVIEWS — auto-reply to positive reviews, alert manager on bad ones.
// Each row mirrors one Google Business Profile review for a tenant. Positive
// reviews (>= autoMinStars) get a drafted reply awaiting one-tap approval;
// low/neutral reviews (<= alertMaxStars) are held for a human and the manager
// is emailed. Connection + settings live in the Setting key "googleReviews".
// ===========================================================================

enum GoogleReviewStatus {
  NEW // just fetched, not yet routed
  DRAFTED // positive → reply drafted, waiting for one-tap approval
  REPLIED // reply posted to Google
  NEEDS_ATTENTION // low/neutral → manager alerted, a human must handle it
  SKIPPED // manager chose to ignore (no reply)
}

model GoogleReview {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Google's own review id (last path segment of the review "name").
  googleReviewId String

  reviewerName  String?
  reviewerPhoto String?
  starRating    Int // 1..5 (mapped from Google's ONE..FIVE enum)
  comment       String? // the review text (may be empty)

  status     GoogleReviewStatus @default(NEW)
  draftReply String? // suggested reply awaiting approval
  replyText  String? // the reply actually posted to Google
  repliedAt  DateTime?
  alertedAt  DateTime? // when the manager was emailed (dedupe)

  reviewCreatedAt DateTime? // Google's review create time
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, googleReviewId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("google_reviews")
}

// ===========================================================================
// MESSENGER BOT — an AI receptionist on the salon's Facebook Page that chats
// with customers, collects their details and books appointments. One Page per
// tenant; conversations (threads) are tenant-scoped.
// ===========================================================================

model MessengerConnection {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pageId    String  @unique // Facebook Page id (routes incoming webhooks to a tenant)
  igId      String? @unique // linked Instagram business account id (routes IG DMs)
  pageToken String // Page access token (secret) used to send replies (FB + IG)
  enabled   Boolean @default(false)
  greeting  String? // optional opening line
  aiInstruction String? // brand-voice / extra guidance for the bot
  botFacts  Json  @default("[]") // structured FAQ facts [{label,value,on}] injected into the bot

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messenger_connections")
}

model MessengerThread {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pageId   String
  senderId String // the customer's page-scoped id (PSID)

  history  Json    @default("[]") // recent turns for context
  lastText String? // last customer message (admin preview)
  handoff  Boolean @default(false) // a human took over → bot stays quiet

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, senderId])
  @@index([tenantId])
  @@index([tenantId, updatedAt])
  @@map("messenger_threads")
}

// ===========================================================================
// AI Voice hotline — the salon KEEPS its own public phone number and forwards
// (on no-answer / busy) to an assigned Lumio voice number. Twilio answers,
// transcribes speech, runs the shared booking agent, and speaks replies.
// The tenant is resolved from the Lumio number the call arrives on (the "To").
// ===========================================================================
model VoiceLine {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Lumio-owned number (E.164) the salon forwards to. Routes calls → tenant.
  lumioNumber   String? @unique
  enabled       Boolean @default(false)
  greeting      String? // spoken welcome line (includes the AI disclosure)
  language      String  @default("en-US") // Twilio speech recognition + TTS language
  voice         String? // optional Twilio <Say> voice name
  aiInstruction String? // extra brand-voice guidance for the agent

  // Monthly plan limits (Super Admin set). 0 = unlimited. Overage in cents.
  monthlyCents       Int     @default(0) // AI Hotline add-on subscription fee / month (0 = bundled in plan)
  includedMinutes    Int     @default(0)
  includedSms        Int     @default(0)
  overageCentsPerMin Int     @default(0)
  overageCentsPerSms Int     @default(0)
  hardCap            Boolean @default(false) // block new AI calls once over included minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("voice_lines")
}

model VoiceCall {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  callSid       String? @unique // Twilio Call SID (per-call session key)
  fromNumber    String? // caller's number (E.164)
  toNumber      String? // the Lumio number dialed
  transcript    Json    @default("[]") // [{role,content}] conversation turns
  outcome       String  @default("in_progress") // in_progress|booked|info|no_action|handoff|error
  appointmentId String?
  durationSec   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("voice_calls")
}

// ===========================================================================
// Invoices — month-end usage-overage bills and plan-renewal bills. Emailed to
// the salon owner with a public hosted page (token) + payment link. Records the
// charge so it is never double-created for the same tenant + type + period.
// ===========================================================================
enum InvoiceType {
  OVERAGE // usage beyond the plan allowance (SMS + AI Hotline minutes)
  RENEWAL // the plan subscription is due for renewal
}

enum InvoiceStatus {
  OPEN
  PAID
  VOID
}

model Invoice {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  number String        @unique // human-friendly, e.g. INV-202607-0007
  token  String        @unique @default(uuid()) // public hosted-invoice page key
  type   InvoiceType
  status InvoiceStatus @default(OPEN)

  currency      String    @default("USD")
  periodStart   DateTime? // month billed (OVERAGE) or period start (RENEWAL)
  periodEnd     DateTime?
  lineItems     Json      @default("[]") // [{label, detail?, amountCents}]
  subtotalCents Int       @default(0)
  totalCents    Int       @default(0)
  dueDate       DateTime?

  sentAt      DateTime? // when the invoice email was sent
  paidAt      DateTime?
  provider    String? // stripe | paypal (when paid)
  externalRef String? // checkout session / payment id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type, periodStart]) // idempotent: one bill per tenant/type/period
  @@index([tenantId, createdAt])
  @@index([status])
  @@map("invoices")
}

// ===========================================================================
// POS (point of sale) — counter checkout: tickets, line items, tenders.
// All tenant-scoped. Optional FKs (service/product/staff/customer/appointment)
// are stored as scalar IDs with names snapshotted onto the line item so a
// receipt is stable even if the catalog later changes.
// ===========================================================================

enum OrderStatus {
  OPEN // ticket being built
  PAID // fully paid / closed
  VOID // cancelled before/after payment (no revenue)
  REFUNDED // money returned after payment
}

enum OrderItemKind {
  SERVICE
  PRODUCT
}

enum PaymentMethod {
  CASH
  CARD
  OTHER
}

/// Retail products sold at the counter (with optional stock tracking).
model Product {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String
  sku             String?
  barcode         String? // scannable barcode / UPC for POS (unique per tenant)
  priceCents      Int
  discountPercent Int     @default(0) // promo % off shown on the ticket/receipt
  currency        String  @default("USD")
  taxable         Boolean @default(true)
  trackStock      Boolean @default(false)
  stockQty        Int     @default(0)
  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("products")
}

/// A POS ticket / sale.
model Order {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderNumber Int // human-friendly, sequential per tenant
  status      OrderStatus @default(OPEN)

  // Optional links (scalar IDs, no relations to keep the schema lean).
  customerId      String?
  appointmentId   String?
  createdByUserId String?
  // Client-generated idempotency key for offline checkout: the same ref is never
  // created twice, so re-syncing a queued offline sale cannot duplicate the order.
  clientRef       String?

  // Money (all in minor units / cents).
  subtotalCents Int    @default(0) // sum of line totals before order discount/tax
  discountCents Int    @default(0) // order-level discount
  taxCents      Int    @default(0) // tax on taxable (retail) lines
  tipCents      Int    @default(0) // total tips across lines
  totalCents    Int    @default(0) // amount due
  paidCents     Int    @default(0) // amount tendered
  changeCents   Int    @default(0) // change returned (cash)
  currency      String @default("USD")

  // Gift card applied to this ticket (redemption). The applied amount is NOT new
  // revenue (it was counted when the card was sold), so the Payment mirror
  // excludes it to avoid double-counting.
  giftCardCode         String?
  giftCardAppliedCents Int     @default(0)

  note   String?
  items  OrderItem[]
  tenders OrderPayment[]

  createdAt DateTime  @default(now())
  paidAt    DateTime?
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, orderNumber])
  @@unique([tenantId, clientRef])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("orders")
}

/// One line on a ticket — a service or a retail product, with the technician
/// who performed/sold it (for per-tech revenue, tips and commission).
model OrderItem {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  kind      OrderItemKind
  serviceId String?
  productId String?
  name      String // snapshot of service/product name

  unitPriceCents Int
  quantity       Int @default(1)
  discountCents  Int @default(0)
  taxCents       Int @default(0)
  tipCents       Int @default(0)
  lineTotalCents Int // unitPrice*qty - discount (tax/tip tracked separately)

  staffMemberId String? // technician credited for this line

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([orderId])
  @@index([tenantId, staffMemberId])
  @@map("order_items")
}

/// Loyalty points ledger: +points earned on paid visits, -points on redemption.
model LoyaltyTransaction {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  points       Int // positive = earned, negative = redeemed
  balanceAfter Int // customer's balance right after this transaction
  reason       String // e.g. "Earned on order #12", "Redeemed for discount"
  refType      String? // 'order' | 'appointment'
  refId        String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@map("loyalty_transactions")
}

/// A tender against an order (supports split payment).
model OrderPayment {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method     PaymentMethod
  amountCents Int

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([orderId])
  @@map("order_payments")
}

enum GiftCardStatus {
  ACTIVE // has balance, usable
  REDEEMED // fully used (zero balance)
  VOID // cancelled by the salon
}

/// Prepaid gift cards sold by a salon. Balance is decremented on redemption at
/// the POS. Belongs to exactly one tenant; codes are unique within the tenant.
model GiftCard {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code         String // shown to the customer; unique within the tenant
  initialCents Int
  balanceCents Int
  currency     String         @default("USD")
  status       GiftCardStatus @default(ACTIVE)

  purchaserName    String?
  recipientName    String?
  recipientContact String?
  note             String?
  expiresAt        DateTime?

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions GiftCardTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("gift_cards")
}

/// Ledger of every balance change on a gift card (issue, redeem, adjust, void).
model GiftCardTransaction {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  giftCardId String
  giftCard   GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  kind        String // ISSUE | REDEEM | ADJUST | VOID
  amountCents Int // + for issue/top-up, - for redemption
  orderId     String?

  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([giftCardId])
  @@map("gift_card_transactions")
}

/// Direct tips paid straight to a technician (scanned their QR, or cash). The
/// salon never holds this money — it is logged only so payroll/reports can show
/// each tech's tips. NOT salon revenue and NOT a salon liability.
model TipLog {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  amountCents Int
  method      String  @default("DIRECT") // DIRECT (QR) | CASH | OTHER
  note        String?
  orderId     String?

  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([staffMemberId])
  @@map("tip_logs")
}

// Customer-facing display relay. Lets an INDEPENDENT device (e.g. a wireless
// iPad on a stand) mirror the register in near-real-time over the network,
// instead of only a same-PC second monitor. One session per tenant:
//   - token: long secret the paired device uses to poll state + post tips.
//   - pairCode: short human code shown on the register to link a device once.
//   - state: latest client-facing display payload (order lines, totals, paid).
//   - payTicket: server-only tech split + ref for the after-payment QR tip.
//   - lastTipRef: idempotency guard so a tip is recorded once per paid ticket.
model DisplaySession {
  id         String   @id @default(uuid())
  tenantId   String   @unique
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  token      String   @unique
  pairCode   String   @unique
  state      Json?
  payTicket  Json?
  lastTipRef String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@map("display_sessions")
}

// Receipt print queue for the reception-desk print agent. The phone enqueues a
// pre-rendered text receipt; a small agent on the salon's reception PC polls
// (with the salon's API key), prints it, and reports the result.
enum PrintJobStatus {
  PENDING
  PRINTED
  FAILED
}

model PrintJob {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status      PrintJobStatus @default(PENDING)
  title       String?
  text        String // pre-rendered plain-text receipt the agent prints
  copies      Int            @default(1)
  createdById String?
  createdAt   DateTime       @default(now())
  printedAt   DateTime?
  error       String?

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("print_jobs")
}
