# ===========================================================================
# Lumio Booking API - Environment variables (EXAMPLE)
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ===========================================================================

# --- Server ---
# Backend API runs on port 8005 (frontend runs on 3005)
PORT=8005
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3005

# --- Database (PostgreSQL) ---
# Matches docker-compose.yml (host port 5433 -> container 5432)
DATABASE_URL="postgresql://lumio:lumio_dev_password@localhost:5433/lumio_booking?schema=public"

# --- Auth (used from Step 3 onward) ---
# Generate a strong random secret, e.g.: openssl rand -base64 48
JWT_SECRET="change_me_use_a_long_random_secret"
# Comfortable for local dev. In production use a short access token (e.g. 15m).
JWT_ACCESS_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="7d"

# Salt rounds for hashing passwords and API/license keys
BCRYPT_SALT_ROUNDS=12

# --- Notification providers (mock by default, real later) ---
# Options: mock | sendgrid | resend | ses
EMAIL_PROVIDER=mock
# SMS auto-enables Twilio when the TWILIO_* vars below are set. Leave blank to
# auto-detect; set to "mock" to force-disable real SMS.
SMS_PROVIDER=

# Twilio (platform-level, one account for all salons). From the Twilio Console.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# Use ONE sender — a Messaging Service (recommended; handles STOP/HELP) ...
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ... or a single toll-free/long-code number in E.164:
# TWILIO_FROM_NUMBER=+18337195153

# (Email) Real provider keys go here later
# SENDGRID_API_KEY=

# --- Payment provider (mock by default, Stripe later) ---
# Options: mock | stripe
PAYMENT_PROVIDER=mock
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Redis (queue system, used later) ---
REDIS_URL="redis://localhost:6380"
